## Racialisation of voting


```{r}
race_ballots <- ballots |> 
  mutate(ethnicity = ifelse(ethnicity == "Orang Asli", "Other", ethnicity)) |> 
  mutate(count = 1) |> 
  group_by(seat, election, federal) |> 
  summarise(
    malay_candidates = sum(count[ethnicity == "Malay"]), 
    chinese_candidates = sum(count[ethnicity == "Chinese"]), 
    indian_candidates = sum(count[ethnicity == "Indian"]), 
    bumi_sabah_candidates = sum(count[ethnicity == "Bumi Sabah"]), 
    bumi_sarawak_candidates = sum(count[ethnicity == "Bumi Sarawak"]), 
    other_candidates = sum(count[ethnicity == "Other"]), 
    total_candidates = n_distinct(candidate_uid), 
    malay_won = sum(count[result %in% c("won", "won_uncontested") & 
                            ethnicity == "Malay"]), 
    chinese_won = sum(count[result %in% c("won", "won_uncontested") & 
                            ethnicity == "Chinese"]), 
    indian_won = sum(count[result %in% c("won", "won_uncontested") & 
                            ethnicity == "Indian"]), 
    bumi_sabah_won = sum(count[result %in% c("won", "won_uncontested") & 
                            ethnicity == "Bumi Sabah"]), 
    bumi_sarawak_won = sum(count[result %in% c("won", "won_uncontested") & 
                            ethnicity == "Bumi Sarawak"]), 
    other_won = sum(count[result %in% c("won", "won_uncontested") & 
                            ethnicity == "Other"]), 
    .groups = "drop"
  ) |> 
  mutate(
    malay_count = ifelse(malay_candidates > 0, 1, 0), 
    chinese_count = ifelse(chinese_candidates > 0, 1, 0),
    indian_count = ifelse(indian_candidates > 0, 1, 0),
    bumi_sabah_count = ifelse(bumi_sabah_candidates > 0, 1, 0),
    bumi_sarawak_count = ifelse(bumi_sarawak_candidates > 0, 1, 0),
    other_count = ifelse(other_candidates > 0, 1, 0), 
    number_ethnicities = malay_count + chinese_count + indian_count + 
      bumi_sabah_count + bumi_sarawak_count + other_count
  ) |> 
  select(-c(malay_count:other_count)) 

