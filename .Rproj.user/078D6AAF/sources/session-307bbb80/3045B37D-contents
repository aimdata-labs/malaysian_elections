  )) |> 
  ggplot(aes(
    x = value, 
    y = high_density
  )) + 
  geom_col(aes(fill = high_density)) + 
  scale_fill_viridis_d(begin = .2, end = .9, 
                       option = "plasma") +
  facet_wrap(~ fct_rev(var), ncol = 1, scales = "free") +
