ph_win_chance = ifelse(ph_win_chance > 1, 1, ph_win_chance))
testing_preds |>
left_join(
ballots |>
filter(election == "GE-15" & result %in% c("won", "won_uncontested")) |>
select(state, seat, coalition, party),
by = c("parlimen" = "seat")
) |>
mutate(ph_win_chance = ifelse(
