scale_colour_viridis_d(option = "turbo") +
scale_x_continuous(breaks = seq(1955, 2026, 5)) +
scale_y_continuous(breaks = seq(0, 300, 20)) +
guides(colour = guide_legend(override.aes = list(linewidth = 2,
