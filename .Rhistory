pn_win_chance = ifelse(pn_win_chance > 1, 1, pn_win_chance)) |>
filter(pn_win_chance >= .5) |>
nrow()
pn_ge_15 <- ballots |>
mutate(count = 1) |>
filter(election == "GE-15" & result %in% c("won", "won_uncontested")) |>
group_by(coalition) |>
summarise(count = sum(count), .groups = "drop") |>
